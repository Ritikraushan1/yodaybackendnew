{% extends "admin/layout.njk" %}
{% set active = "dashboard" %}

{% block content %}
<div class="min-h-screen bg-gradient-to-br from-purple-50 via-blue-50 to-pink-50">
  <!-- Header Section -->
  <div class="mb-8">
    <h1 class="text-5xl font-black bg-gradient-to-r from-purple-600 via-pink-600 to-blue-600 bg-clip-text text-transparent mb-2">
      Welcome back, {{ user.name }}! 👋
    </h1>
    <p class="text-gray-600 text-lg">Here's what's happening with your platform today</p>
  </div>

  <!-- Stats Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
    <!-- Total Posts -->
    <div class="group bg-gradient-to-br from-purple-500 to-purple-700 p-6 rounded-3xl shadow-xl hover:shadow-2xl transition-all duration-300 hover:-translate-y-1 cursor-pointer">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-sm font-semibold text-purple-100 uppercase tracking-wide">Total Posts</h2>
          <p class="text-5xl font-black mt-3 text-white">{{ stats.total_posts or "0" }}</p>
        </div>
        <div class="bg-white/20 p-4 rounded-2xl backdrop-blur-sm">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
          </svg>
        </div>
      </div>
    </div>

    <!-- Total Comments -->
    <div class="group bg-gradient-to-br from-pink-500 to-rose-700 p-6 rounded-3xl shadow-xl hover:shadow-2xl transition-all duration-300 hover:-translate-y-1 cursor-pointer">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-sm font-semibold text-pink-100 uppercase tracking-wide">Total Comments</h2>
          <p class="text-5xl font-black mt-3 text-white">{{ stats.total_comments or "0" }}</p>
        </div>
        <div class="bg-white/20 p-4 rounded-2xl backdrop-blur-sm">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
        </div>
      </div>
    </div>

    <!-- Total Users -->
    <div class="group bg-gradient-to-br from-blue-500 to-indigo-700 p-6 rounded-3xl shadow-xl hover:shadow-2xl transition-all duration-300 hover:-translate-y-1 cursor-pointer">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-sm font-semibold text-blue-100 uppercase tracking-wide">Total Users</h2>
          <p class="text-5xl font-black mt-3 text-white">{{ stats.total_users or "0" }}</p>
        </div>
        <div class="bg-white/20 p-4 rounded-2xl backdrop-blur-sm">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
        </div>
      </div>
    </div>

    <!-- Total Likes -->
    <div class="group bg-gradient-to-br from-red-500 to-orange-600 p-6 rounded-3xl shadow-xl hover:shadow-2xl transition-all duration-300 hover:-translate-y-1 cursor-pointer">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-sm font-semibold text-red-100 uppercase tracking-wide">Total Likes</h2>
          <p class="text-5xl font-black mt-3 text-white">{{ stats.total_likes or "0" }}</p>
        </div>
        <div class="bg-white/20 p-4 rounded-2xl backdrop-blur-sm">
          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 10.5a1.5 1.5 0 113 0v6a1.5 1.5 0 01-3 0v-6zM6 10.333v5.43a2 2 0 001.106 1.79l.05.025A4 4 0 008.943 18h5.416a2 2 0 001.962-1.608l1.2-6A2 2 0 0015.56 8H12V4a2 2 0 00-2-2 1 1 0 00-1 1v.667a4 4 0 01-.8 2.4L6.8 10.133a1.5 1.5 0 00-.8.2z"/>
          </svg>
        </div>
      </div>
    </div>

    <!-- New Users (24h) -->
    <div class="group bg-gradient-to-br from-green-500 to-emerald-700 p-6 rounded-3xl shadow-xl hover:shadow-2xl transition-all duration-300 hover:-translate-y-1 cursor-pointer">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-sm font-semibold text-green-100 uppercase tracking-wide">New Users (24h)</h2>
          <p class="text-5xl font-black mt-3 text-white">{{ stats.new_users_24h or "0" }}</p>
        </div>
        <div class="bg-white/20 p-4 rounded-2xl backdrop-blur-sm">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
          </svg>
        </div>
      </div>
    </div>

    <!-- Post Today -->
    <div class="group bg-gradient-to-br from-amber-500 to-yellow-600 p-6 rounded-3xl shadow-xl hover:shadow-2xl transition-all duration-300 hover:-translate-y-1 cursor-pointer">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-sm font-semibold text-amber-100 uppercase tracking-wide">Post Done Today?</h2>
          <div class="mt-3">
            {% if stats.post_today == 'Yes' %}
              <span class="inline-flex items-center px-5 py-2 rounded-full text-lg font-bold bg-white text-green-600 shadow-lg">
                <svg class="w-6 h-6 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                Yes
              </span>
            {% else %}
              <span class="inline-flex items-center px-5 py-2 rounded-full text-lg font-bold bg-white text-red-600 shadow-lg">
                <svg class="w-6 h-6 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                </svg>
                No
              </span>
            {% endif %}
          </div>
        </div>
        <div class="bg-white/20 p-4 rounded-2xl backdrop-blur-sm">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Recent Posts Activity -->
  <div class="bg-white rounded-3xl shadow-2xl border border-gray-100 overflow-hidden backdrop-blur-lg">
    <div class="px-8 py-6 bg-gradient-to-r from-purple-600 via-pink-600 to-blue-600">
      <div class="flex items-center justify-between">
        <h2 class="text-2xl font-black text-white flex items-center">
          <svg class="w-7 h-7 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
          </svg>
          Latest Activity
        </h2>
        <span class="text-white/80 text-sm font-medium">Recent Posts</span>
      </div>
    </div>
    
    <div class="p-8">
      {% if latestPosts and latestPosts.length > 0 %}
        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr class="border-b-2 border-gray-200">
                <th class="pb-4 text-xs font-bold text-gray-500 uppercase tracking-wider">Post Content</th>
                <th class="pb-4 text-xs font-bold text-gray-500 uppercase tracking-wider">Engagement</th>
                <th class="pb-4 text-xs font-bold text-gray-500 uppercase tracking-wider">Date</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {% for post in latestPosts %}
                <tr class="hover:bg-gradient-to-r hover:from-purple-50 hover:to-pink-50 transition-all duration-200 group">
                  <td class="py-5 pr-6">
                    <p class="text-sm text-gray-800 font-medium line-clamp-2 leading-relaxed">{{ post.content }}</p>
                    <span class="inline-flex items-center mt-2 px-3 py-1 rounded-full text-xs font-bold bg-gradient-to-r from-purple-100 to-pink-100 text-purple-700">
                      #{{ post.post_code }}
                    </span>
                  </td>
                  <td class="py-5">
                    <div class="flex items-center space-x-5">
                      <span class="flex items-center text-sm font-bold text-green-600 bg-green-50 px-3 py-2 rounded-xl group-hover:bg-green-100 transition-colors" title="Likes">
                        <svg class="w-5 h-5 mr-1.5" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M2 10.5a1.5 1.5 0 113 0v6a1.5 1.5 0 01-3 0v-6zM6 10.333v5.43a2 2 0 001.106 1.79l.05.025A4 4 0 008.943 18h5.416a2 2 0 001.962-1.608l1.2-6A2 2 0 0015.56 8H12V4a2 2 0 00-2-2 1 1 0 00-1 1v.667a4 4 0 01-.8 2.4L6.8 10.133a1.5 1.5 0 00-.8.2z"/>
                        </svg>
                        {{ post.like_count }}
                      </span>
                      <span class="flex items-center text-sm font-bold text-red-600 bg-red-50 px-3 py-2 rounded-xl group-hover:bg-red-100 transition-colors" title="Dislikes">
                        <svg class="w-5 h-5 mr-1.5" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M18 9.5a1.5 1.5 0 11-3 0v-6a1.5 1.5 0 013 0v6zM14 9.667v-5.43a2 2 0 00-1.106-1.79l-.05-.025A4 4 0 0011.057 2H5.64a2 2 0 00-1.962 1.608l-1.2 6A2 2 0 004.44 12H8v4a2 2 0 002 2 1 1 0 001-1v-.667a4 4 0 01.8-2.4l1.4-1.866a1.5 1.5 0 00.8-.2z"/>
                        </svg>
                        {{ post.dislike_count }}
                      </span>
                      <span class="flex items-center text-sm font-bold text-blue-600 bg-blue-50 px-3 py-2 rounded-xl group-hover:bg-blue-100 transition-colors" title="Comments">
                        <svg class="w-5 h-5 mr-1.5" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L2 17l1.338-3.123C2.493 12.767 2 11.434 2 10c0-3.866 3.582-7 8-7s8 3.134 8 7zM7 9H5v2h2V9zm8 0h-2v2h2V9zM9 9h2v2H9V9z" clip-rule="evenodd"/>
                        </svg>
                        {{ post.comment_count }}
                      </span>
                    </div>
                  </td>
                  <td class="py-5 whitespace-nowrap">
                    <div class="flex items-center text-xs text-gray-500 font-medium">
                      <svg class="w-4 h-4 mr-1.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                      {{ post.created_at | formatDate }}
                    </div>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      {% else %}
        <div class="text-center py-16">
          <svg class="w-20 h-20 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
          </svg>
          <p class="text-gray-500 text-lg font-medium">No recent activity found.</p>
          <p class="text-gray-400 text-sm mt-2">Posts will appear here once users start engaging</p>
        </div>
      {% endif %}
    </div>
  </div>
</div>
{% endblock %}